                }
            },
            "file": {
                "path": "/tmp/"
            },
            "frames": 0,
            "acquisition_id": "test_1",
            "write": false,
            "timeout_timer_period": 10000,
            "process": {
                "number": 1,
                "rank": 0
            }
        },
        "Liveview":       
        {
            "per_second": 1,
            "live_view_socket_addr": "tcp://0.0.0.0:5021",
            "dataset_name": "dummy",
            "filter_tagged": ""
        }
    }
