[
    {
        "fr_setup": {
            "fr_ready_cnxn": "tcp://0.0.0.0:6969",
            "fr_release_cnxn": "tcp://0.0.0.0:6970"
        }
    },
    {
        "plugin": {
            "load": {
                "index": "HexitecMhz",
                "name": "HexitecMhzPlugin",
                "library": "./lib/libHexitecMhzDetectorPlugin.so"
            }
        }
    },
    {
        "plugin": {
            "load": {
                "index": "Liveview",
                "name": "LiveViewPlugin",
                "library": "./lib/libLiveViewPlugin.so"
            }
        }
    },
    {
        "plugin": {
            "load": {
                "index": "hdf",
                "name": "FileWriterPlugin",
                "library": "./lib/libHdf5Plugin.so"
            }
        }
    },
    {
        "plugin": {
            "connect": {
                "index": "HexitecMhz",
                "connection": "frame_receiver"
            }
        }
    },
    {
        "plugin": {
            "connect": {
                "index": "Liveview",
                "connection": "HexitecMhz"
            }
        }
    },
    {
        "plugin": {
            "connect": {
                "index": "hdf",
                "connection": "Liveview"
            }
        }
    },
    {
        "HexitecMhz": {
            "mode": "histogram_1024",
            "update_config": false,
            "dpdk_process_rank": 0,
            "num_secondary_processes": 0,
            "shared_buffer_size": 107374182400,
            "socket": 0,
            "dpdk_eal": {
                "corelist": "16-31",
                "loglevel": "debug",
                "proc-type": "Primary",
                "file-prefix": "hist-1024-odin-data"
            },
            "worker_cores": {
                "packet_rx": {
                    "core_name": "PacketRxCore",
                    "num_cores": 1,
                    "pcie_device": "0000:2b:00.1",
                    "rx_ports": [
                        40101,
                        40102,
                        40103,
                        40104,
                        40105,
                        40106,
                        40107,
                        40108
                    ],
                    "device_ip": "10.0.100.6",
                    "rx_burst_size": 128,
                    "fwd_ring_size": 131072,
                    "release_ring_size": 131072,
                    "rx_queue_id": 0,
                    "tx_queue_id": 0,
                    "max_packet_tx_retries": 64,
                    "max_packet_queue_retries": 64
                },
                "packet_processor": {
                    "core_name": "PacketProcessorCore",
                    "num_cores": 2,
                    "connect": "packet_rx",
                    "frame_timeout": 1000
                },
                "frame_builder": {
                    "core_name": "FrameBuilderCore",
                    "num_cores": 2,
                    "connect": "packet_processor",
                    "secondary_fanout": false
                },
                "frame_wrapper": {
                    "core_name": "FrameWrapperCore",
                    "num_cores": 1,
                    "connect": "frame_builder"
                }
            }
        }
    },
    {
        "hdf": {
            "dataset": {
                "dummy": {
                    "datatype": "uint32",
                    "dims": [
                        80,
                        80,
                        1024
                    ],
